    </value>
  </Operation>

  <!-- GeneralLaborSpeed -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Mech_Fabricor"]/statBases</xpath>
    <value>
      <GeneralLaborSpeed>40</GeneralLaborSpeed>
    </value>
  </Operation>

  <!-- DrugSynthesisSpeed -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Mech_Fabricor"]/statBases</xpath>
    <value>
      <DrugSynthesisSpeed>20</DrugSynthesisSpeed>
    </value>
  </Operation>

  <!-- SmeltingSpeed -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Mech_Fabricor"]/statBases</xpath>
    <value>
      <SmeltingSpeed>40</SmeltingSpeed>
    </value>
  </Operation>

  


</Patch>