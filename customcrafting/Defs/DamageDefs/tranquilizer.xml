<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <DamageDef ParentName="Bullet">
        <defName>CC_SleepDart</defName>
        <label>tranquilizer</label>
        <workerClass>DamageWorker_AddInjury</workerClass>
        <!-- <hediff>CC_AnestheticEffect</hediff> -->

        <hediffSolid>Gunshot</hediffSolid>
        <harmAllLayersUntilOutside>false</harmAllLayersUntilOutside>
        <additionalHediffs>
        <li>
            <hediff>CC_AnestheticEffect</hediff>
            <severityPerDamageDealt>1</severityPerDamageDealt>
        </li>
        </additionalHediffs>
        <defaultDamage>1</defaultDamage>
        <armorCategory>Sharp</armorCategory>
        <externalViolence>true</externalViolence>
        <harmAllLayersUntilOutside>false</harmAllLayersUntilOutside>
        <canInterruptJobs>true</canInterruptJobs>
        <makesBlood>true</makesBlood>
        <deathMessage>{0} was tranquilized by {1}.</deathMessage>
    </DamageDef>
</Defs>