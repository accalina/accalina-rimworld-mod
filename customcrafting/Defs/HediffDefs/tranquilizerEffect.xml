<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef ParentName="DiseaseBase">
        <defName>CC_AnestheticEffect</defName>
        <label>tranquilized</label>
        <hediffClass>HediffWithComps</hediffClass>
        <description>Sleep drugs in the bloodstream. Anesthetic renders creatures unconscious.</description>
        <initialSeverity>1</initialSeverity>
        <maxSeverity>1</maxSeverity>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>120000</disappearsAfterTicks>
                <!-- ~2 in-game hours -->
            </li>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-1</severityPerDay>
            </li>
        </comps>
        <stages>
            <li>
                <label>tranquilized</label>
                <minSeverity>0.1</minSeverity>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.5</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>unconscious</label>
                <minSeverity>0.6</minSeverity>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <setMax>0.01</setMax>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
</Defs>